{
  "name": "@todos/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "The Todos MCP server's tools and board logic, transport-free — mounted by the hosted connector in apps/web/api.",
  "type": "module",
  "main": "./dist/mcp.js",
  "types": "./dist/mcp.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@todos/sheet-core": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
